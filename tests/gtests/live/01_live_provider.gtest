#SET SCRIPT=${WORK_DIR}/run_live_provider.sh
#MKDIR ${WORK_DIR}/artifacts
#MKDIR ${WORK_DIR}/artifacts/live-gtests
#MKDIR ${WORK_DIR}/artifacts/live-gtests/01_live_provider
#MKDIR ${WORK_DIR}/artifacts/live-gtests/01_live_provider/artifacts
#WRITE ${SCRIPT} <<<EOF
#!/usr/bin/env bash
set -euo pipefail
repo_root="$1"
if [ ! -f "${repo_root}/.secrets" ]; then
  echo "No ${repo_root}/.secrets file found."
  echo "Set up the live test first:"
  echo "  cp .secrets.sample .secrets"
  echo "  ollama serve"
  echo "  ollama pull llama3:8b"
  echo "Then rerun: greentic-integration-tester run --gtest tests/gtests/live --artifacts-dir artifacts/live-gtests --errors"
  exit 0
fi
set -a
. "${repo_root}/.secrets"
set +a
mkdir -p "${repo_root}/artifacts/live-gtests/01_live_provider"
cargo test --manifest-path "${repo_root}/Cargo.toml" live_provider_roundtrip --test live_provider -- --exact --nocapture \
  2>&1 | tee "${repo_root}/artifacts/live-gtests/01_live_provider/cargo-test.log"
EOF
#RUN bash ${SCRIPT} ${REPO_ROOT}
#EXPECT_EXIT 0
#SAVE_ARTIFACT ${SCRIPT}
#SAVE_ARTIFACT ${REPO_ROOT}/artifacts/live-gtests/01_live_provider/cargo-test.log
