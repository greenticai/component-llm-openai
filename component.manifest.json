{
  "$schema": "https://greenticai.github.io/greentic-component/schemas/v1/component.manifest.schema.json",
  "artifacts": {
    "component_wasm": "target/wasm32-wasip2/release/component_llm_openai.wasm"
  },
  "capabilities": {
    "host": {
      "http": {
        "client": true,
        "server": false
      },
      "messaging": {
        "inbound": true,
        "outbound": true
      },
      "secrets": {
        "required": []
      },
      "telemetry": {
        "scope": "node"
      }
    },
    "wasi": {
      "clocks": true,
      "filesystem": {
        "mode": "none",
        "mounts": []
      },
      "random": true
    }
  },
  "config_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "additionalProperties": false,
    "default": {
      "api_key_secret": null,
      "base_url": null,
      "default_model": null,
      "provider": "openai",
      "timeout_ms": null
    },
    "examples": [
      {
        "api_key_secret": "OPENAI_API_KEY",
        "default_model": "gpt-4.1-mini",
        "provider": "openai"
      },
      {
        "base_url": "http://localhost:11434/v1",
        "default_model": "llama3:8b",
        "provider": "ollama"
      },
      {
        "api_key_secret": "CUSTOM_KEY",
        "base_url": "https://my-gateway/v1",
        "default_model": "gpt-4.1-mini",
        "provider": "custom"
      }
    ],
    "properties": {
      "api_key_secret": {
        "description": "Secret key name resolved via greentic-secrets. Required for OpenAI, OpenRouter, Together.",
        "type": "string"
      },
      "base_url": {
        "description": "Optional override of the base URL. Required for provider=custom.",
        "type": "string"
      },
      "default_model": {
        "description": "Optional default model for this component instance.",
        "type": "string"
      },
      "provider": {
        "default": "openai",
        "description": "Provider to talk to. Defaults to openai.",
        "enum": [
          "openai",
          "ollama",
          "openrouter",
          "together",
          "custom"
        ],
        "type": "string"
      },
      "timeout_ms": {
        "description": "Optional request timeout in milliseconds if supported by the host HTTP client.",
        "minimum": 0,
        "type": "integer"
      }
    },
    "required": [],
    "title": "component-llm-openai component configuration",
    "type": "object",
    "x-capabilities": {
      "host": {
        "http": true,
        "secrets": true
      }
    }
  },
  "describe_export": "get-manifest",
  "hashes": {
    "component_wasm": "blake3:4a7ef0ea33e16ccf559b938a834a3201abf6c11e12ce1fc1f1f6f92f499492b4"
  },
  "id": "ai.greentic.component-llm-openai",
  "limits": {
    "memory_mb": 128,
    "wall_time_ms": 1000
  },
  "name": "component-llm-openai",
  "profiles": {
    "default": "stateless",
    "supported": [
      "stateless"
    ]
  },
  "supports": [
    "messaging"
  ],
  "version": "0.1.0",
  "world": "greentic:component/component@0.5.0"
}

